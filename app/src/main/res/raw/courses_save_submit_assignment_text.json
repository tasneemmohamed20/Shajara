      "method": "POST",
      "moodle_function": "mod_assign_save_submission",
      "url": "/webservice/rest/server.php",
      "request": {
        "wsfunction": "mod_assign_save_submission",
        "wstoken": "{{token}}",
        "moodlewsrestformat": "json",
        "assignmentid": "501",
        "plugindata[onlinetext_editor][text]": "<p>Crime Scene Analysis Report...</p>",
        "plugindata[onlinetext_editor][format]": "1",
        "plugindata[onlinetext_editor][itemid]": "{{draft_item_id}}"
      },
      "response": {
        "warnings": []
      }
    }
  }
}