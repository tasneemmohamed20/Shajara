{
  "endpoints": {
    "forgot_password": {
      "description": "Forgot Password - Send reset email",
      "method": "POST",
      "moodle_function": "core_auth_request_password_reset",
      "url": "/webservice/rest/server.php",
      "request": {
        "wsfunction": "core_auth_request_password_reset",
        "wstoken": "{{token}}",
        "moodlewsrestformat": "json",
        "username": "ahmed.almansoori",
        "email": "ahmed@sharjahpolice.ae"
      },
      "response": {
        "status": "emailpasswordconfirmsent",
        "notice": "An email has been sent to your address. It contains easy instructions to confirm and complete this password change."
      }
    }
  }
}