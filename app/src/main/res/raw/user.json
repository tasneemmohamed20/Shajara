    "post_user_preferences": {
      "description": "Save user preferences (language, notification settings)",
      "method": "POST",
      "moodle_function": "core_user_update_user_preferences",
      "url": "/webservice/rest/server.php",
      "request": {
        "wsfunction": "core_user_update_user_preferences",
        "wstoken": "{{token}}",
        "moodlewsrestformat": "json",
        "userid": "{{userid}}",
        "preferences[0][name]": "lang",
        "preferences[0][value]": "ar",
        "preferences[1][name]": "notification_enabled",
        "preferences[1][value]": "1"
      },
      "response": {
        "saved": true,
        "warnings": []
      }
    },
    "post_profile_picture": {
      "description": "Upload and set profile picture",
      "method": "POST",
      "moodle_function": "core_user_update_picture",
      "url": "/webservice/rest/server.php",
      "note": "First upload file via core_files_upload, then pass draftitemid here.",
      "request": {
        "wsfunction": "core_user_update_picture",
        "wstoken": "{{token}}",
        "moodlewsrestformat": "json",
        "draftitemid": "{{draft_item_id}}",
        "delete": "0",
        "userid": "{{userid}}"
      },
      "response": {
        "success": true,
        "profileimageurl": "https://lms.sharjahpolice.ae/pluginfile.php/42/user/icon/f1?rev=2",
        "warnings": []
      }
