    "get_issued_certificates": {
      "description": "Get all certificates issued to user — Profile screen (Certificates section)",
      "method": "GET",
      "moodle_function": "mod_certificate_get_issued_certificates",
      "url": "/webservice/rest/server.php",
      "note": "Requires mod_certificate or mod_customcert plugin. Use mod_customcert_get_issued_certificates if using Custom Certificate plugin.",
